# PostgreSQL connection string
# Local dev: postgresql://postgres:password@localhost:5432/oshi_polling
# Neon (free): get from https://neon.tech after creating a project
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Admin credentials - change these before deploying!
ADMIN_PASSWORD="change_me_before_deploying"
ADMIN_SECRET="a_long_random_secret_string_at_least_32_chars"

# Salt for IP address hashing (privacy protection)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_SALT="another_long_random_string"
